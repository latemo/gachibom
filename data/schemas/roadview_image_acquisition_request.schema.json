{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jeju-maeum.local/schemas/roadview_image_acquisition_request.schema.json",
  "title": "Jeju Maeum Roadview Image Acquisition Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "source_roadview_image_review_generated_at",
    "source_dataset",
    "summary",
    "items"
  ],
  "properties": {
    "generated_at": { "type": "string", "format": "date" },
    "source_roadview_image_review_generated_at": { "type": ["string", "null"], "format": "date" },
    "source_dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "url",
        "provider",
        "application_required",
        "expected_full_dataset_image_count",
        "expected_service_seed_image_count",
        "expected_priority_sample_image_count",
        "note"
      ],
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "provider": { "type": "string" },
        "application_required": { "type": "boolean" },
        "expected_full_dataset_image_count": { "type": "integer", "minimum": 0 },
        "expected_service_seed_image_count": { "type": "integer", "minimum": 0 },
        "expected_priority_sample_image_count": { "type": "integer", "minimum": 0 },
        "note": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_places",
        "total_requested_images",
        "priority_sample_images",
        "supplemental_images",
        "min_images_per_place",
        "max_images_per_place",
        "by_region",
        "by_category"
      ],
      "properties": {
        "total_places": { "type": "integer", "minimum": 0 },
        "total_requested_images": { "type": "integer", "minimum": 0 },
        "priority_sample_images": { "type": "integer", "minimum": 0 },
        "supplemental_images": { "type": "integer", "minimum": 0 },
        "min_images_per_place": { "type": "integer", "minimum": 0 },
        "max_images_per_place": { "type": "integer", "minimum": 0 },
        "by_region": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_category": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/requestItem" }
    }
  },
  "$defs": {
    "requestItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card",
        "image_count",
        "priority_sample_count",
        "supplemental_image_count",
        "captured_date_start",
        "captured_date_end",
        "coordinate_bounds",
        "priority_images",
        "supplemental_images",
        "requested_delivery",
        "recommended_action"
      ],
      "properties": {
        "card": { "$ref": "#/$defs/cardRef" },
        "image_count": { "type": "integer", "minimum": 0 },
        "priority_sample_count": { "type": "integer", "minimum": 0 },
        "supplemental_image_count": { "type": "integer", "minimum": 0 },
        "captured_date_start": { "type": ["string", "null"], "format": "date" },
        "captured_date_end": { "type": ["string", "null"], "format": "date" },
        "coordinate_bounds": { "$ref": "#/$defs/coordinateBounds" },
        "priority_images": {
          "type": "array",
          "items": { "$ref": "#/$defs/requestImage" }
        },
        "supplemental_images": {
          "type": "array",
          "items": { "$ref": "#/$defs/requestImage" }
        },
        "requested_delivery": { "$ref": "#/$defs/requestedDelivery" },
        "recommended_action": { "type": "string" }
      }
    },
    "requestImage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_file_name",
        "request_tier",
        "tourist_name",
        "tourist_name_en",
        "captured_at",
        "latitude",
        "longitude",
        "resolution"
      ],
      "properties": {
        "image_file_name": { "type": "string", "minLength": 1 },
        "request_tier": {
          "type": "string",
          "enum": ["priority_visual_review_sample", "supplemental_place_sequence"]
        },
        "tourist_name": { "type": "string" },
        "tourist_name_en": { "type": "string" },
        "captured_at": { "type": ["string", "null"] },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "resolution": { "type": "string" }
      }
    },
    "requestedDelivery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_name_preservation_required",
        "accepted_extensions",
        "target_directory",
        "priority_first"
      ],
      "properties": {
        "file_name_preservation_required": { "type": "boolean" },
        "accepted_extensions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "target_directory": { "type": "string" },
        "priority_first": { "type": "boolean" }
      }
    },
    "coordinateBounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_latitude", "max_latitude", "min_longitude", "max_longitude"],
      "properties": {
        "min_latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "max_latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "min_longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "max_longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 }
      }
    },
    "cardRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "region", "category", "verification_status"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "region": { "type": "string" },
        "category": { "type": "string" },
        "verification_status": { "type": "string" }
      }
    }
  }
}
