{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jeju-maeum.local/schemas/operations_readiness_report.schema.json",
  "title": "Jeju Maeum Operations Readiness Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "criteria",
    "overall_status",
    "summary",
    "sections",
    "blockers",
    "warnings",
    "next_actions"
  ],
  "properties": {
    "generated_at": { "type": "string", "format": "date" },
    "criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ready_for_full_service", "ready_with_warnings", "blocked_for_full_service"],
      "properties": {
        "ready_for_full_service": { "type": "string" },
        "ready_with_warnings": { "type": "string" },
        "blocked_for_full_service": { "type": "string" }
      }
    },
    "overall_status": {
      "type": "string",
      "enum": ["ready_for_full_service", "ready_with_warnings", "blocked_for_full_service"]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_checks",
        "passed_checks",
        "warning_checks",
        "blocker_checks",
        "by_status",
        "next_action"
      ],
      "properties": {
        "total_checks": { "type": "integer", "minimum": 0 },
        "passed_checks": { "type": "integer", "minimum": 0 },
        "warning_checks": { "type": "integer", "minimum": 0 },
        "blocker_checks": { "type": "integer", "minimum": 0 },
        "by_status": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "next_action": { "type": "string" }
      }
    },
    "sections": {
      "type": "array",
      "items": { "$ref": "#/$defs/section" }
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "checks"],
      "properties": {
        "name": { "type": "string" },
        "status": { "$ref": "#/$defs/checkStatus" },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/check" }
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "status",
        "severity",
        "actual",
        "expected",
        "detail",
        "next_action"
      ],
      "properties": {
        "check_id": { "type": "string" },
        "status": { "$ref": "#/$defs/checkStatus" },
        "severity": { "type": "string", "enum": ["warning", "blocker"] },
        "actual": { "type": "string" },
        "expected": { "type": "string" },
        "detail": { "type": "string" },
        "next_action": { "type": "string" }
      }
    },
    "checkStatus": {
      "type": "string",
      "enum": ["pass", "warn", "block"]
    }
  }
}
