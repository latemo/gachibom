{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jeju-maeum.local/schemas/roadview_image_asset_manifest.schema.json",
  "title": "Jeju Maeum Roadview Image Asset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "source_roadview_image_review_generated_at",
    "asset_root",
    "source_dataset",
    "summary",
    "items"
  ],
  "properties": {
    "generated_at": { "type": "string", "format": "date" },
    "source_roadview_image_review_generated_at": { "type": ["string", "null"], "format": "date" },
    "asset_root": { "type": "string" },
    "source_dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "url",
        "provider",
        "application_required",
        "expected_full_dataset_image_count",
        "expected_full_dataset_size_gb",
        "note"
      ],
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "provider": { "type": "string" },
        "application_required": { "type": "boolean" },
        "expected_full_dataset_image_count": { "type": "integer", "minimum": 0 },
        "expected_full_dataset_size_gb": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_places",
        "total_place_images",
        "expected_review_sample_images",
        "available_review_sample_images",
        "missing_review_sample_images",
        "by_status",
        "by_review_decision"
      ],
      "properties": {
        "total_places": { "type": "integer", "minimum": 0 },
        "total_place_images": { "type": "integer", "minimum": 0 },
        "expected_review_sample_images": { "type": "integer", "minimum": 0 },
        "available_review_sample_images": { "type": "integer", "minimum": 0 },
        "missing_review_sample_images": { "type": "integer", "minimum": 0 },
        "by_status": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_review_decision": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/manifestItem" }
    }
  },
  "$defs": {
    "manifestItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card",
        "status",
        "expected_review_sample_count",
        "available_review_sample_count",
        "missing_review_sample_count",
        "total_place_image_count",
        "review_decision",
        "images",
        "recommended_action"
      ],
      "properties": {
        "card": { "$ref": "#/$defs/cardRef" },
        "status": { "type": "string", "enum": ["ready_for_visual_review", "missing_assets"] },
        "expected_review_sample_count": { "type": "integer", "minimum": 0 },
        "available_review_sample_count": { "type": "integer", "minimum": 0 },
        "missing_review_sample_count": { "type": "integer", "minimum": 0 },
        "total_place_image_count": { "type": "integer", "minimum": 0 },
        "review_decision": {
          "type": "string",
          "enum": ["ready_for_visual_review", "asset_acquisition_required"]
        },
        "images": {
          "type": "array",
          "items": { "$ref": "#/$defs/imageAsset" }
        },
        "recommended_action": { "type": "string" }
      }
    },
    "imageAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_file_name",
        "captured_at",
        "latitude",
        "longitude",
        "resolution",
        "expected_relative_paths",
        "present_path",
        "status"
      ],
      "properties": {
        "image_file_name": { "type": "string", "minLength": 1 },
        "captured_at": { "type": ["string", "null"] },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "resolution": { "type": "string" },
        "expected_relative_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "present_path": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["available", "missing"] }
      }
    },
    "cardRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "region", "category", "verification_status"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "region": { "type": "string" },
        "category": { "type": "string" },
        "verification_status": { "type": "string" }
      }
    }
  }
}
