{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jeju-maeum.local/schemas/app_recommendation_seed.schema.json",
  "title": "Jeju Maeum App Recommendation Seed",
  "type": "object",
  "additionalProperties": false,
  "required": ["generated_at", "safety_notice", "public_gate", "saved_route_places", "visual_assets", "official_courses", "scenarios"],
  "properties": {
    "generated_at": { "type": "string", "format": "date" },
    "safety_notice": { "type": "string", "minLength": 1 },
    "public_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_places",
        "app_candidate_places",
        "status_counts",
        "verification_counts",
        "excluded_statuses",
        "pending_gate_note"
      ],
      "properties": {
        "total_places": { "type": "integer", "minimum": 0 },
        "app_candidate_places": { "type": "integer", "minimum": 0 },
        "status_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "verification_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "excluded_statuses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pending_gate_note": { "type": "string", "minLength": 1 }
      }
    },
    "saved_route_places": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["spot_id", "name", "region", "category", "available", "duration_minutes", "info_url", "location", "visit_info"],
        "properties": {
          "spot_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,80}$" },
          "name": { "type": "string", "minLength": 1, "maxLength": 100 },
          "region": { "type": "string", "maxLength": 120 },
          "category": { "type": "string", "minLength": 1, "maxLength": 80 },
          "available": { "type": "boolean" },
          "duration_minutes": { "type": ["integer", "null"], "minimum": 1, "maximum": 600 },
          "info_url": { "type": "string", "maxLength": 2048, "pattern": "^(?:https?://.*)?$" },
          "location": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["latitude", "longitude", "point_role"],
                "properties": {
                  "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
                  "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
                  "point_role": {
                    "type": "string",
                    "enum": ["poi", "facility", "route_start", "route_start_end", "route_end_reference", "viewpoint"]
                  }
                }
              }
            ]
          },
          "visit_info": { "$ref": "#/$defs/visitInfo" }
        }
      }
    },
    "visual_assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["src", "caption"],
        "properties": {
          "src": { "type": "string" },
          "caption": { "type": "string" }
        }
      }
    },
    "official_courses": {
      "type": "array",
      "items": { "$ref": "#/$defs/officialCourse" }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    }
  },
  "$defs": {
    "officialCourse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "overview",
        "recommended_travelers",
        "total_move_minutes",
        "total_travel_minutes",
        "recommendation_by_type",
        "stops"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "overview": { "type": "string" },
        "recommended_travelers": { "type": "string" },
        "total_move_minutes": { "type": ["integer", "null"] },
        "total_travel_minutes": { "type": ["integer", "null"] },
        "recommendation_by_type": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "stops": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "order",
              "name",
              "spot_id",
              "matched_name",
              "category",
              "verification_status",
              "location_available",
              "promoted_candidate",
              "description",
              "cautions"
            ],
            "properties": {
              "order": { "type": ["integer", "null"] },
              "name": { "type": "string" },
              "spot_id": { "type": "string" },
              "matched_name": { "type": "string" },
              "category": { "type": "string" },
              "verification_status": { "type": "string" },
              "location_available": { "type": "boolean" },
              "promoted_candidate": { "type": "boolean" },
              "description": { "type": "string" },
              "cautions": { "type": "string" }
            }
          }
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "title", "traveler_summary", "recommendation", "places"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "title": { "type": "string" },
        "traveler_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["traveler_type", "mobility_conditions", "preferred_themes", "required_accessibility", "avoid"],
          "properties": {
            "traveler_type": { "type": "array", "items": { "type": "string" } },
            "mobility_conditions": { "type": "array", "items": { "type": "string" } },
            "preferred_themes": { "type": "array", "items": { "type": "string" } },
            "required_accessibility": { "type": "array", "items": { "type": "string" } },
            "avoid": { "type": "array", "items": { "type": "string" } }
          }
        },
        "recommendation": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "traveler_summary",
            "course",
            "score",
            "recommended_spots",
            "fit_reasons",
            "deduction_reasons",
            "check_before_visit",
            "source_summary",
            "safety_notice"
          ],
          "properties": {
            "course": {
              "type": "object",
              "additionalProperties": true,
              "required": ["title", "summary", "pace", "route"],
              "properties": {
                "title": { "type": "string" },
                "summary": { "type": "string" },
                "pace": { "type": "string" },
                "route": {
                  "type": "array",
                  "items": { "type": "object" }
                }
              }
            },
            "score": {
              "type": "object",
              "additionalProperties": true,
              "required": ["total", "grade", "confidence", "breakdown"],
              "properties": {
                "total": { "type": "integer", "minimum": 0, "maximum": 100 },
                "grade": { "type": "string" },
                "confidence": { "type": "string" },
                "breakdown": { "type": "object" }
              }
            },
            "recommended_spots": { "type": "array", "items": { "type": "string" } },
            "fit_reasons": { "type": "array", "items": { "type": "string" } },
            "deduction_reasons": { "type": "array", "items": { "type": "string" } },
            "check_before_visit": { "type": "array", "items": { "type": "string" } },
            "source_summary": { "type": "array", "items": { "type": "object" } },
            "safety_notice": { "type": "string" }
          }
        },
        "places": {
          "type": "array",
          "items": { "$ref": "#/$defs/placeResult" }
        }
      }
    },
    "placeResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spot_id",
        "name",
        "region",
        "category",
        "summary",
        "score",
        "fit_reasons",
        "deduction_reasons",
        "check_before_visit",
        "source_summary",
        "blocked",
        "block_reasons",
        "verification_status",
        "verification",
        "accessibility",
        "effort",
        "location",
        "safety_notes",
        "avoid_for",
        "visit_info"
      ],
      "properties": {
        "spot_id": { "type": "string" },
        "name": { "type": "string" },
        "region": { "type": "string" },
        "category": { "type": "string" },
        "summary": { "type": "string" },
        "score": {
          "type": "object",
          "additionalProperties": true,
          "required": ["total", "grade", "confidence", "breakdown"],
          "properties": {
            "total": { "type": "integer", "minimum": 0, "maximum": 100 },
            "grade": { "type": "string" },
            "confidence": { "type": "string" },
            "breakdown": { "type": "object" }
          }
        },
        "fit_reasons": { "type": "array", "items": { "type": "string" } },
        "deduction_reasons": { "type": "array", "items": { "type": "string" } },
        "check_before_visit": { "type": "array", "items": { "type": "string" } },
        "source_summary": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "url", "status"],
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        },
        "blocked": { "type": "boolean" },
        "block_reasons": { "type": "array", "items": { "type": "string" } },
        "verification_status": { "type": "string" },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "checked_at", "missing_fields"],
          "properties": {
            "status": { "type": "string" },
            "checked_at": { "type": "string" },
            "missing_fields": { "type": "array", "items": { "type": "string" } }
          }
        },
        "accessibility": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "label", "state", "state_label", "note"],
            "properties": {
              "field": { "type": "string" },
              "label": { "type": "string" },
              "state": { "type": "string" },
              "state_label": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        },
        "effort": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "walking_level",
            "recommended_duration_minutes",
            "outdoor_exposure",
            "weather_sensitivity"
          ],
          "properties": {
            "walking_level": { "type": "string" },
            "recommended_duration_minutes": { "type": ["integer", "null"], "minimum": 0 },
            "outdoor_exposure": { "type": "string" },
            "weather_sensitivity": { "type": "string" }
          }
        },
        "location": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": [
            "latitude",
            "longitude",
            "source",
            "source_title",
            "source_url",
            "matched_name",
            "match_method",
            "evidence_count",
            "point_role"
          ],
          "properties": {
            "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
            "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
            "source": { "type": "string" },
            "source_title": { "type": "string" },
            "source_url": { "type": "string" },
            "matched_name": { "type": "string" },
            "match_method": { "type": "string" },
            "evidence_count": { "type": "integer", "minimum": 1 },
            "point_role": {
              "type": "string",
              "enum": ["poi", "facility", "route_start", "route_start_end", "route_end_reference", "viewpoint"]
            }
          }
        },
        "safety_notes": { "type": "array", "items": { "type": "string" } },
        "avoid_for": { "type": "array", "items": { "type": "string" } },
        "visit_info": { "$ref": "#/$defs/visitInfo" }
      }
    },
    "visitInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "address",
        "phone",
        "operating_hours",
        "official_url",
        "reservation_url",
        "service_status",
        "notice",
        "verification_status",
        "last_verified_at",
        "source_updated_at",
        "missing_fields",
        "evidence"
      ],
      "properties": {
        "address": { "type": ["string", "null"] },
        "phone": { "type": ["string", "null"] },
        "operating_hours": { "type": ["string", "null"] },
        "official_url": { "type": ["string", "null"], "pattern": "^https?://" },
        "reservation_url": { "type": ["string", "null"], "pattern": "^https?://" },
        "service_status": {
          "type": "string",
          "enum": ["active", "temporarily_closed", "permanently_closed", "unknown"]
        },
        "notice": { "type": ["string", "null"] },
        "verification_status": {
          "type": "string",
          "enum": ["verified", "partial", "needs_check"]
        },
        "last_verified_at": { "type": ["string", "null"], "format": "date" },
        "source_updated_at": { "type": ["string", "null"], "format": "date" },
        "missing_fields": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/visitInfoEvidence" }
        }
      }
    },
    "visitInfoEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fields",
        "status",
        "source_title",
        "source_url",
        "source_type",
        "checked_at",
        "observed_at",
        "note"
      ],
      "properties": {
        "fields": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "enum": ["verified", "partial", "needs_check", "not_applicable"]
        },
        "source_title": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "pattern": "^https?://" },
        "source_type": {
          "type": "string",
          "enum": ["official", "public_agency", "operator_verified", "partner_verified", "user_feedback", "unknown"]
        },
        "checked_at": { "type": ["string", "null"], "format": "date" },
        "observed_at": { "type": ["string", "null"], "format": "date" },
        "note": { "type": "string" }
      }
    }
  }
}
