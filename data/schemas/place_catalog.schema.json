{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jeju-maeum.local/schemas/place_catalog.schema.json",
  "title": "Jeju Maeum Raw Place Catalog Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "catalog_id",
    "name",
    "category",
    "region",
    "address",
    "source",
    "ingestion",
    "matching",
    "status"
  ],
  "properties": {
    "catalog_id": {
      "type": "string",
      "pattern": "^catalog_[a-z0-9_]+_[0-9a-f]{8}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": ["sea", "forest", "oreum", "culture", "indoor", "cafe", "restaurant", "food_market", "shopping", "rest_area", "transport", "medical_support", "lodging", "event", "experience", "other"]
    },
    "region": {
      "type": "string"
    },
    "address": {
      "type": ["string", "null"]
    },
    "phone": {
      "type": ["string", "null"]
    },
    "homepage": {
      "type": ["string", "null"]
    },
    "latitude": {
      "type": ["number", "null"],
      "minimum": -90,
      "maximum": 90
    },
    "longitude": {
      "type": ["number", "null"],
      "minimum": -180,
      "maximum": 180
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "description": {
      "type": ["string", "null"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "dataset_name", "license", "updated_at"],
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "dataset_name": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date"
        }
      }
    },
    "ingestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["imported_at", "raw_category", "raw_id", "raw_hash"],
      "properties": {
        "imported_at": {
          "type": "string",
          "format": "date"
        },
        "raw_category": {
          "type": ["string", "null"]
        },
        "raw_id": {
          "type": ["string", "null"]
        },
        "raw_hash": {
          "type": "string"
        }
      }
    },
    "matching": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accessibility_card_id", "match_status", "match_confidence"],
      "properties": {
        "accessibility_card_id": {
          "type": ["string", "null"]
        },
        "match_status": {
          "type": "string",
          "enum": ["matched", "candidate", "unmatched", "manual_review"]
        },
        "match_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "hidden", "deprecated", "blocked"]
    }
  }
}
