{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jeju-maeum.local/schemas/roadview_visual_review_sheet.schema.json",
  "title": "Jeju Maeum Roadview Visual Review Sheet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "source_roadview_image_review_generated_at",
    "source_image_asset_manifest_generated_at",
    "criteria",
    "summary",
    "items"
  ],
  "properties": {
    "generated_at": { "type": "string", "format": "date" },
    "source_roadview_image_review_generated_at": { "type": ["string", "null"], "format": "date" },
    "source_image_asset_manifest_generated_at": { "type": ["string", "null"], "format": "date" },
    "criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verified", "needs_follow_up"],
      "properties": {
        "verified": { "type": "string" },
        "needs_follow_up": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_places",
        "by_status",
        "by_review_decision",
        "total_field_results",
        "by_field_status"
      ],
      "properties": {
        "total_places": { "type": "integer", "minimum": 0 },
        "by_status": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_review_decision": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "total_field_results": { "type": "integer", "minimum": 0 },
        "by_field_status": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/reviewSheetItem" }
    }
  },
  "$defs": {
    "reviewSheetItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "card",
        "status",
        "review_decision",
        "image_asset_status",
        "review_image_samples",
        "field_results",
        "reviewer_checklist",
        "recommended_action"
      ],
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "card": { "$ref": "#/$defs/cardRef" },
        "status": { "type": "string", "enum": ["open", "blocked", "resolved"] },
        "review_decision": {
          "type": "string",
          "enum": ["asset_required", "pending_reviewer_input", "visual_review_complete", "needs_follow_up"]
        },
        "image_asset_status": { "type": "string" },
        "review_image_samples": {
          "type": "array",
          "items": { "$ref": "#/$defs/imageAsset" }
        },
        "field_results": {
          "type": "array",
          "items": { "$ref": "#/$defs/fieldResult" }
        },
        "reviewer_checklist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommended_action": { "type": "string" }
      }
    },
    "fieldResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "status",
        "image_file_names",
        "evidence_image_file_names",
        "reviewer_note",
        "reviewer",
        "reviewed_at"
      ],
      "properties": {
        "field": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending_visual_review", "verified", "needs_follow_up", "conflict", "missing"]
        },
        "image_file_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_image_file_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reviewer_note": { "type": "string" },
        "reviewer": { "type": ["string", "null"] },
        "reviewed_at": { "type": ["string", "null"], "format": "date" },
        "ai_suggestion": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["status", "evidence_image_file_names", "note", "confidence"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["verified", "needs_follow_up", "conflict", "missing"]
            },
            "evidence_image_file_names": {
              "type": "array",
              "items": { "type": "string" }
            },
            "note": { "type": "string" },
            "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
          }
        }
      }
    },
    "imageAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_file_name",
        "captured_at",
        "latitude",
        "longitude",
        "resolution",
        "expected_relative_paths",
        "present_path",
        "status"
      ],
      "properties": {
        "image_file_name": { "type": "string", "minLength": 1 },
        "captured_at": { "type": ["string", "null"] },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "resolution": { "type": "string" },
        "expected_relative_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "present_path": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["available", "missing"] }
      }
    },
    "cardRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "region", "category", "verification_status"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "region": { "type": "string" },
        "category": { "type": "string" },
        "verification_status": { "type": "string" }
      }
    }
  }
}
