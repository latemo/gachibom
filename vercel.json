{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.py": {
      "includeFiles": "data/**",
      "excludeFiles": "{tests/**,docs/**,web/assets/**,.playwright-mcp/**,.serena/**,*.png,*.jpg,*.jpeg,*.mp4,*.pptx,*.docx}"
    }
  },
  "routes": [
    { "src": "/\\.env(.*)", "status": 404 },
    { "src": "/api/help-chat", "dest": "/api/help_chat.py" },
    { "src": "/api/(.*)", "dest": "/api/$1.py" },
    { "src": "/data/(.*)", "dest": "/web/data/$1" },
    { "src": "/assets/(.*)", "dest": "/web/assets/$1" },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/web/index.html" },
    { "src": "/(.*)", "dest": "/web/$1" }
  ]
}
