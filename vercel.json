{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.py": {
      "includeFiles": "data/{jeju_{accessible_spots,accessible_public_toilets,power_wheelchair_fast_chargers},place_{location_overrides,visit_info_overrides},place_catalog.roadview_facility,roadview_image_metadata,tourism_weak_recommendation_courses}.json",
      "excludeFiles": "{tests/**,docs/**,scripts/**,web/assets/**,data/raw/**,.playwright-mcp/**,.serena/**,.tmp-*/**,.vercel/**,*.png,*.jpg,*.jpeg,*.mp4,*.pptx,*.docx}"
    }
  },
  "routes": [
    { "src": "/\\.env(.*)", "status": 404 },
    { "src": "/src(.*)", "status": 404 },
    { "src": "/scripts(.*)", "status": 404 },
    { "src": "/tests(.*)", "status": 404 },
    { "src": "/docs(.*)", "status": 404 },
    { "src": "/api/(.*)\\.py", "status": 404 },
    { "src": "/README\\.md", "status": 404 },
    { "src": "/design-qa\\.md", "status": 404 },
    { "src": "/pyproject\\.toml", "status": 404 },
    { "src": "/uv\\.lock", "status": 404 },
    { "src": "/\\.python-version", "status": 404 },
    { "src": "/data/operations_readiness_report\\.json", "status": 404 },
    { "src": "/data/recommendation_case_validation_report\\.json", "status": 404 },
    { "src": "/data/service_launch_action_plan\\.json", "status": 404 },
    { "src": "/help-chatbot\\.html", "status": 404 },
    { "src": "/miro_service_concept\\.html", "status": 404 },
    { "src": "/api/help-chat", "dest": "/api/help_chat.py" },
    { "src": "/api/(.*)", "dest": "/api/$1.py" },
    { "src": "/data/(.*)", "dest": "/web/data/$1" },
    { "src": "/assets/(.*)", "dest": "/web/assets/$1" },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/web/index.html" },
    { "src": "/(.*)", "dest": "/web/$1" }
  ]
}
